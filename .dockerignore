# Version control
.git
.gitignore

# Python cache
__pycache__
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
venv/
.venv/
env/
ENV/

# Node / frontend build artifacts
node_modules/
package-lock.json

# Django collected static (regenerated during build)
static/

# Media files (mounted as a Docker volume — not baked into image)
media/

# Logs
logs/
*.log

# Local env overrides (secrets must come from runtime env, not image)
.env
.env.*
!.env.example

# Test / coverage artifacts
.coverage
htmlcov/
.pytest_cache/
coverage.xml

# IDE / editor
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Temporary files
tmp/
*.tmp
